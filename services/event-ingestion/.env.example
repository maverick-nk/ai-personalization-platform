# Copy this file to .env and fill in the values before running the service.
#   cp .env.example .env
#
# Never commit .env — it is listed in the root .gitignore.

# ── Kafka ──────────────────────────────────────────────────────────────────────
# Host-accessible Kafka listener (EXTERNAL, port 29092).
# Use localhost:29092 when running the service on the host machine.
# Use kafka:9092 when running inside the Docker network.
KAFKA_BOOTSTRAP_SERVERS=localhost:29092

# ── Privacy ────────────────────────────────────────────────────────────────────
# Secret key for HMAC-SHA256 user ID pseudonymization.
# Must be consistent across all deployments — rotating this key makes existing
# pseudo_user_ids in Redis and Parquet incomparable to new ones.
# Generate a strong value with: openssl rand -hex 32
PSEUDONYMIZE_SECRET=change-me
