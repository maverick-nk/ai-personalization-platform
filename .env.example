# Copy to .env and fill in values before running docker-compose.
# Do NOT commit .env — it is gitignored.

# ── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform

# ── Kafka ──────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── MLflow ─────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000

# ── Privacy service DB ─────────────────────────────────────────────────────
PRIVACY_DB_URL=postgresql://platform:platform@postgres:5432/privacy

# ── Event pseudonymization ─────────────────────────────────────────────────
# Used by event-ingestion for HMAC-SHA256 user ID pseudonymization.
# Generate with: openssl rand -hex 32
PSEUDONYM_SECRET=replace-with-a-32-byte-hex-secret
